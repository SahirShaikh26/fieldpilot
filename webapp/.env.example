# Backend API base URL (defaults to /api if unset)
VITE_API_URL=https://your-backend.up.railway.app/api

# Monitoring (optional — leave unset to skip Sentry in the webapp)
VITE_SENTRY_DSN=

# Comma-separated emails allowed to see the Status nav item (mirror backend OWNER_EMAILS)
VITE_OWNER_EMAILS=you@example.com
