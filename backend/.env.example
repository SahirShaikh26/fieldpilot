PORT=4000
DATABASE_URL=postgresql://user:password@host:5432/fieldpilot
JWT_SECRET=change_this_to_a_long_random_string
NODE_ENV=production

# Public URL of the webapp (not currently used by billing, kept for reference)
WEBAPP_URL=https://your-app.vercel.app

# Razorpay billing (leave unset to run without billing — routes degrade gracefully)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PRO=

# Monitoring (leave SENTRY_DSN unset to skip Sentry — error logging to the DB still works)
SENTRY_DSN=
OWNER_EMAILS=you@example.com

# AI Daily Digest (leave unset to disable — route degrades gracefully)
ANTHROPIC_API_KEY=
